{
    "name": "default-dark-plus-intellij",
    "displayName": "Default Dark+ IntelliJ Theme",
    "description": "A theme extension coupling the IntelliJ Darcula syntax colour scheme with improved VSCode's Default Dark+ UI colours.",
    "version": "1.4.0",
    "publisher": "niccolomineo",
    "license": "MIT",
    "homepage": "https://github.com/niccolomineo/vscode-default-dark-plus-intellij-theme#readme",
    "repository": {
        "type": "git",
        "url": "https://github.com/niccolomineo/vscode-default-dark-plus-intellij-theme"
    },
    "bugs": {
        "url": "https://github.com/niccolomineo/vscode-default-dark-plus-intellij-theme/issues"
    },
    "engines": {
        "vscode": "^1.70.0"
    },
    "categories": [
        "Themes"
    ],
    "keywords": [
        "theme",
        "dark",
        "intellij",
        "darcula",
        "dark+"
    ],
    "galleryBanner": {
        "color": "#1E1E1E",
        "theme": "dark"
    },
    "icon": "icon.png",
    "contributes": {
        "themes": [
            {
                "label": "Default Dark+ IntelliJ Theme",
                "uiTheme": "vs-dark",
                "path": "./themes/default-dark-plus-intellij-theme.json"
            }
        ]
    },
    "scripts": {
        "package": "vsce package",
        "publish": "vsce publish"
    },
    "devDependencies": {
        "@vscode/vsce": "^3.2.1"
    }
}
